    </comp>
    <comp lib="6" loc="(445,5575)" name="Text">
      <a name="font" val="SansSerif bold 14"/>
      <a name="text" val="MASTER-SLAVE = APPENA APRO INGRESSO CON LE PORTE AND, CHIUDO L'USCITA E VICEVERSA"/>
    </comp>
    <comp lib="6" loc="(445,5680)" name="Text">
