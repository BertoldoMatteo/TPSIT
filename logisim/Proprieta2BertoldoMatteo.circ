    </comp>
    <comp lib="6" loc="(420,6495)" name="Text">
      <a name="font" val="SansSerif bold 14"/>
      <a name="text" val="PASSO 3: REIMPOSTO IL VALORE DI CLOCK A 0. FRONTE DI DISCESA, ORA IL SEGNALE"/>
    </comp>
    <comp lib="6" loc="(420,6520)" name="Text">
      <a name="font" val="SansSerif bold 14"/>
